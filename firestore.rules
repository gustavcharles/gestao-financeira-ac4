rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // Curto-circuito é essencial aqui: se isOwner for true, o motor não executa o isAdmin()
    // Isso evita a recursão infinita que bloqueia o acesso.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      let profilePath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && exists(profilePath) && get(profilePath).data.role == 'admin';
    }

    function isDev() {
      let profilePath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && exists(profilePath) && get(profilePath).data.role == 'dev';
    }

    function isDataOwner() {
      let dataUid = 'user_id' in resource.data ? resource.data.user_id : ('userId' in resource.data ? resource.data.userId : null);
      return isAuthenticated() && dataUid == request.auth.uid;
    }

    // --- Collections ---

    // Users: Dono tem prioridade total (curto-circuito). Admin/Dev vem depois.
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin() || isDev();
      
      // Permitir consulta por e-mail (anti-abuse) - list é para queries
      allow list: if request.query.limit <= 1;

      match /{subcollection=**} {
        allow read, write: if isOwner(userId) || isAdmin() || isDev();
      }
    }

    // Transactions (transacoes)
    match /transacoes/{docId} {
      allow create: if isAuthenticated();
      // Se for criação de um novo doc (resource == null), permitimos se estiver logado
      // Se for leitura/update de doc existente, checamos dono ou admin
      allow read, update, delete: if isAdmin() || isDataOwner();
    }

    // User settings
    match /user_settings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Scales & Shifts
    match /scales/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || isDataOwner();
    }

    match /shifts/{docId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || isDataOwner();
    }

    // App Config & Feedback
    match /app_config/{document=**} {
      allow read, write: if isAdmin() || isDev();
    }

    match /app_feedback/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || isDev();
    }
  }
}
